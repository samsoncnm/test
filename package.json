{
  "name": "nl-script",
  "version": "0.1.0",
  "description": "自然语言脚本探索与固定脚本执行系统",
  "type": "module",
  "bin": {
    "nl-script": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "lint": "biome check ./src",
    "lint:fix": "biome check --write ./src",
    "postinstall": "pnpm build"
  },
  "dependencies": {
