    "@midscene/core": "^1.7.5",
    "@midscene/cli": "^1.7.5",
    "playwright": "^1.49.0",
    "@playwright/test": "^1.49.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "uuid": "^10.0.0",
    "yaml": "^2.6.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "@biomejs/biome": "^1.9.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
