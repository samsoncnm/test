# Virtual environment
.venv/

# Environment variables (contains secrets)
.env

# Python
__pycache__/
*.py[cod]
*.pyc
.pytest_cache/
.mypy_cache/

# Editor
.DS_Store
.vscode/
.idea/

# Browser session state (contains auth tokens — DO NOT commit)
auth-state.json
auth-state-*.json

# Node.js dependencies (auto-generated by npm install)
node_modules/

# Compiled output (generated by tsc)
dist/

# Midscene runtime artifacts (auto-generated during execution)
midscene_run/

# Local scripts (may contain credentials)
scripts/

# Local plans & docs
plans/

# Claude agent config (local only)
.claude/

# Cursor settings (local only)
.cursor/
