# Midscene 模型配置
# 将以下值替换为你的实际配置

# ========== 主模型（视觉定位） ==========
# 必填。主模型负责视觉定位和 UI 元素识别。
# 模型服务地址（注意：末尾需要包含 /v1）
MIDSCENE_MODEL_BASE_URL="https://your-model-service.com/v1"

# API Key
MIDSCENE_MODEL_API_KEY="your-api-key-here"

# 模型名称
MIDSCENE_MODEL_NAME="your-model-name"

# 模型系列（如 qwen3-vl、doubao-seed 等）
MIDSCENE_MODEL_FAMILY="qwen3-vl"

# ========== Planning 模型（规划决策）[可选] ==========
# 用于复杂任务规划。配置后，规划推理卸载到专用模型，主模型专注视觉定位。
# 如果不配置，规划能力由主模型兼任。
# 示例：使用 DeepSeek 做规划，Qwen3-VL-Plus 做视觉定位
# MIDSCENE_PLANNING_MODEL_BASE_URL="https://api.deepseek.com"
# MIDSCENE_PLANNING_MODEL_API_KEY="sk-..."
# MIDSCENE_PLANNING_MODEL_NAME="deepseek-chat"
# MIDSCENE_PLANNING_MODEL_FAMILY="deepseek"

# ========== Insight 模型（页面理解）[可选] ==========
# 用于深度页面理解（aiQuery、aiAssert 等）。
# 如果不配置，页面理解由主模型兼任。
# 示例：使用 DeepSeek 做页面分析
# MIDSCENE_INSIGHT_MODEL_BASE_URL="https://api.deepseek.com"
# MIDSCENE_INSIGHT_MODEL_API_KEY="sk-..."
# MIDSCENE_INSIGHT_MODEL_NAME="deepseek-chat"
# MIDSCENE_INSIGHT_MODEL_FAMILY="deepseek"

# ========== 其他可选配置 ==========

# 可选：解决截图字体缺失问题
# PW_TEST_SCREENSHOT_NO_FONTS_READY=1

# 可选：模型推理力度（low, medium, high），仅部分模型支持
# MIDSCENE_MODEL_REASONING_EFFORT="medium"
